# ── API Keys ─────────────────────────────────────────────────────────
ODDS_API_KEY=your_odds_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── BallDontLie GOAT Tier ($39.99/mo) ────────────────────────────────
# Get your key at https://app.balldontlie.io
# When set, BDL becomes primary data source for props, injuries, lineups
# Odds API is preserved for Pinnacle/sharp book consensus only
BDL_API_KEY=your_bdl_api_key_here
BDL_PROP_VENDORS=draftkings,fanduel,caesars,betmgm,betrivers,bet365

# ── Model Tuning ─────────────────────────────────────────────────────
EDGE_MIN=0.05
MIN_PROJECTED_MINUTES=15.0
ODDS_REGION=us
BOOKMAKERS=draftkings,fanduel,betmgm,caesars

# ── Risk Management ──────────────────────────────────────────────────
BANKROLL=1000.0
KELLY_FRACTION=0.25

# ── Scheduler ────────────────────────────────────────────────────────
# With BDL enabled, scan can run more frequently (BDL: 600 req/min)
SCAN_INTERVAL_MINUTES=30
QUOTA_FLOOR=30
TWITTER_POLL_INTERVAL=15

# ── Sharp Books ──────────────────────────────────────────────────────
SHARP_BOOKS=pinnacle
REC_BOOKS=draftkings,fanduel
SHARP_EDGE_MIN=0.03
CONSENSUS_BOOKS=pinnacle,circa,bookmaker
CONSENSUS_HOLD_MAX=0.06

# ── Database ─────────────────────────────────────────────────────────
DB_PATH=props.db
LOG_LEVEL=INFO
